# Custom measure (same contract as built-in point-prediction metrics)
my_abs_err <- function(y, mupred, log_weights = NULL) {
  mu <- colMeans(mupred)
  pw <- abs(y - mu)
  list(
    estimate = mean(pw),
    se = sd(pw) / sqrt(length(pw)),
    pointwise = pw
  )
}
